<Window x:Class="Notepad___Clone.FindWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Find / Replace" Height="250" Width="400"
 WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="SearchTabs">
            <TabItem Header="Find">
                <StackPanel Margin="10">
                    <Label Content="Find what:"/>
                    <TextBox x:Name="txtSearchFind" Margin="0,5,0,10"/>
                    <Button Content="Find" Width="100" HorizontalAlignment="Right" Click="FindNext_Click"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Replace">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Find what:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtSearchReplace" Margin="5"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="Replace with:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtReplaceWith" Margin="5"/>

                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Replace" Width="80" Margin="5,0" Click="Replace_Click"/>
                        <Button Content="Replace All" Width="80" Click="ReplaceAll_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <CheckBox x:Name="chkAllTabs" Grid.Row="1" Content="Search in all open tabs" 
               Margin="10,5" VerticalAlignment="Center"/>
    </Grid>
</Window>
